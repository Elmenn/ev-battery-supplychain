{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ev-battery-order-vrc-v5.schema.json",
  "title": "EV Battery Order VRC v5",
  "type": "object",
  "required": [
    "@context",
    "id",
    "type",
    "schemaVersion",
    "issuer",
    "holder",
    "validFrom",
    "credentialSchema",
    "credentialStatus",
    "credentialSubject",
    "proof"
  ],
  "properties": {
    "@context": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "id": {
      "type": "string"
    },
    "type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "schemaVersion": {
      "const": "5.0"
    },
    "issuer": {
      "$ref": "#/$defs/party"
    },
    "holder": {
      "$ref": "#/$defs/party"
    },
    "validFrom": {
      "type": "string"
    },
    "credentialSchema": {
      "$ref": "#/$defs/credentialSchema"
    },
    "credentialStatus": {
      "$ref": "#/$defs/credentialStatus"
    },
    "credentialSubject": {
      "$ref": "#/$defs/credentialSubject"
    },
    "previousVersion": {
      "type": [
        "null",
        "string"
      ]
    },
    "proof": {
      "type": "array",
      "minItems": 1
    }
  },
  "$defs": {
    "party": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "credentialSchema": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "JsonSchema" }
      }
    },
    "credentialStatus": {
      "type": "object",
      "required": ["id", "type", "statusPurpose"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "SupplyChainCredentialStatus2026" },
        "statusPurpose": { "const": "revocation" }
      }
    },
    "proofData": {
      "type": "object",
      "required": ["proofType", "proofRHex", "proofSHex", "contextHash"],
      "properties": {
        "proofType": { "type": "string" },
        "proofRHex": { "type": "string" },
        "proofSHex": { "type": "string" },
        "contextHash": { "type": "string" }
      }
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "productName",
        "batch",
        "productContract",
        "productId",
        "chainId",
        "listing",
        "order",
        "commitments",
        "zkProofs",
        "attestation"
      ],
      "properties": {
        "id": { "type": "string" },
        "productName": { "type": "string" },
        "batch": { "type": "string" },
        "productContract": { "type": "string" },
        "productId": { "type": "string" },
        "chainId": { "type": "string" },
        "listing": { "type": "object" },
        "order": { "type": "object" },
        "commitments": {
          "type": "object",
          "required": ["quantityCommitment", "totalCommitment", "paymentCommitment"]
        },
        "zkProofs": {
          "type": "object",
          "required": ["schemaVersion", "quantityTotalProof", "totalPaymentEqualityProof"],
          "properties": {
            "schemaVersion": { "type": "string" },
            "quantityTotalProof": { "$ref": "#/$defs/proofData" },
            "totalPaymentEqualityProof": { "$ref": "#/$defs/proofData" }
          }
        },
        "attestation": {
          "type": "object",
          "required": ["attestationVersion", "contextHash"],
          "properties": {
            "attestationVersion": { "type": "string" },
            "contextHash": { "type": "string" },
            "disclosurePubKey": { "type": "string" }
          }
        },
        "delivery": {
          "type": ["null", "object"]
        }
      }
    }
  }
}
